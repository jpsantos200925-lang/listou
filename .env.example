# Frontend (Vite) — copie para .env e preencha com seus valores
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Edge Function search-prices — configure nas variáveis de ambiente do Supabase
# Opção A (recomendada): credenciais OAuth2 — token gerado automaticamente a cada chamada
ML_APP_ID=seu_app_id_aqui
ML_APP_SECRET=seu_app_secret_aqui

# Opção B (fallback): token estático — expira e precisa ser rotacionado manualmente
# ML_ACCESS_TOKEN=seu_token_aqui

# NUNCA coloque tokens reais neste arquivo nem os commite no git
